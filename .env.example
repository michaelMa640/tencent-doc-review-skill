# =========================
# LLM 基础配置
# 默认主模型建议使用 deepseek
# 可选值：deepseek / minimax
# =========================
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# =========================
# MiniMax 备选模型配置
# 仅在你要切换到 minimax 时需要填写
# =========================
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7

# =========================
# DeepSeek 兼容字段
# 如果你之前已经使用 DEEPSEEK_* 变量，这里仍然兼容
# =========================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# =========================
# Skill / MCP bridge 配置
# 当前对用户可见的主路径是 OpenClaw + 腾讯文档 MCP
# 可选值：openclaw / claude_code / mock
# 如果你走 OpenClaw + 腾讯文档 MCP：
# 1. 先在腾讯文档 OpenClaw 场景页获取 / 重置 token：
#    https://docs.qq.com/scenario/open-claw.html?nlc=1
# 2. 把拿到的 token 填到下面的 TENCENT_DOCS_TOKEN
# 3. 本项目通常不需要填写 TENCENT_DOCS_CLIENT_ID / TENCENT_DOCS_OPEN_ID
# 4. bridge 相关配置通常可以留空，程序会自动推断
# 5. 只有自动推断失败时，才需要手动填写下面这些 bridge 项
# =========================
SKILL_MCP_CLIENT=openclaw
MCP_BRIDGE_TIMEOUT=120
TENCENT_DOCS_TOKEN=

# OpenClaw bridge 可执行配置（通常留空即可）
OPENCLAW_MCP_BRIDGE_EXECUTABLE=
OPENCLAW_MCP_BRIDGE_ARGS=

# Claude Code bridge 可执行配置（当前仍建议手动填写）
CLAUDE_CODE_MCP_BRIDGE_EXECUTABLE=
CLAUDE_CODE_MCP_BRIDGE_ARGS=

# =========================
# 联网事实核查配置
# 当前已接入 Tavily
# 如果不想联网核查，保留 disabled
# =========================
SEARCH_PROVIDER=disabled
SEARCH_API_KEY=
SEARCH_BASE_URL=https://api.tavily.com/search
SEARCH_MAX_RESULTS=5
SEARCH_TIMEOUT=20
SEARCH_DEPTH=basic
SEARCH_TOPIC=general

# =========================
# 审核模板路径配置
# 用户只需要在这里选择使用哪套模板
# 模板文件本体放在项目根目录 templates/
# =========================
REVIEW_RULES_TEMPLATE_PATH=templates/default_product_research_review_rules.md
REVIEW_STRUCTURE_TEMPLATE_PATH=templates/default_product_research_structure_template.md

# =========================
# 腾讯文档 OpenAPI 直连配置（可选 / 默认不用）
# 只有在你要直接调用项目内置 TencentDocClient 时才需要
# 当前主路径不是这条，所以默认注释掉，避免误导用户
# 这条链路需要同时具备 token / client_id / open_id
# 其中 token 也可以沿用上面 MCP 主路径填写的 TENCENT_DOCS_TOKEN
# =========================
# TENCENT_DOCS_CLIENT_ID=
# TENCENT_DOCS_OPEN_ID=
# TENCENT_DOCS_BASE_URL=https://docs.qq.com/openapi
# TENCENT_DOCS_MAX_RETRIES=2
# TENCENT_DOCS_RETRY_DELAY=1.0

# =========================
# 运行控制
# =========================
BATCH_SIZE=5
REQUEST_TIMEOUT=30
LOG_LEVEL=INFO
